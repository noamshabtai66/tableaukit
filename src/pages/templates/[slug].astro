---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import TableauViz from "../../components/TableauViz.astro";
import DownloadButton from "../../components/DownloadButton.astro";
import FavoriteButton from "../../components/FavoriteButton.astro";

export const prerender = false;

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/templates");
}

const { data: template, error } = await Astro.locals.supabase
  .from("tk_templates")
  .select("*")
  .eq("slug", slug)
  .eq("is_published", true)
  .maybeSingle();

if (error || !template) {
  return Astro.redirect("/templates");
}

// Storage public URL for the .twbx
const { data: twbxUrlData } = Astro.locals.supabase
  .storage
  .from("templates")
  .getPublicUrl(template.twbx_storage_path);

const twbxUrl = twbxUrlData.publicUrl;

let isFavorited = false;
if (Astro.locals.user) {
  const { data: fav } = await Astro.locals.supabase
    .from("tk_favorites")
    .select("template_slug")
    .eq("user_id", Astro.locals.user.id)
    .eq("template_slug", slug)
    .maybeSingle();
  isFavorited = !!fav;
}
---

<Layout title={`${template.name} · TableauKit`} description={template.subtitle}>
  <!-- Tableau Embedding API v3 (only loaded on detail pages) -->
  <script
    is:inline
    type="module"
    src="https://public.tableau.com/javascripts/api/tableau.embedding.3.latest.min.js"
  ></script>

  <Nav user={Astro.locals.user} />

  <main class="mx-auto max-w-6xl px-6 py-12">
    <nav class="mb-8 text-sm text-ink-muted">
      <a href="/templates" class="hover:text-ink-strong">Templates</a>
      <span class="mx-2">/</span>
      <span class="text-ink-strong">{template.name}</span>
    </nav>

    <header class="flex flex-col gap-6 md:flex-row md:items-start md:justify-between">
      <div>
        <h1 class="text-4xl font-semibold tracking-tight text-ink-strong">{template.name}</h1>
        <p class="mt-3 max-w-2xl text-lg text-ink">{template.subtitle}</p>
        <div class="mt-5 flex flex-wrap items-center gap-2 text-[12px]">
          <span class="rounded-sm bg-app px-2.5 py-1 font-medium text-ink-muted">{template.chart_type}</span>
          <span class="rounded-sm bg-app px-2.5 py-1 font-medium text-ink-muted">{template.difficulty}</span>
          <span class="rounded-sm bg-app px-2.5 py-1 font-medium text-ink-muted">≈{template.build_time_min} min build</span>
          {template.tags && template.tags.map((tag: string) => (
            <span class="rounded-sm border border-line bg-panel px-2.5 py-1 text-ink-muted">{tag}</span>
          ))}
        </div>
      </div>
      <div class="flex flex-wrap items-center gap-3">
        <DownloadButton href={twbxUrl} filename={`${template.slug}.twbx`} />
        <FavoriteButton user={Astro.locals.user} templateSlug={template.slug} isFavorited={isFavorited} />
      </div>
    </header>

    <section class="mt-10">
      <TableauViz src={template.tableau_public_url} title={template.name} />
    </section>

    <section class="mt-12 grid grid-cols-1 gap-10 lg:grid-cols-[1.4fr_1fr]">
      <article class="prose prose-sm max-w-none">
        <h2 class="text-2xl font-semibold text-ink-strong">How the XML works</h2>
        <div class="mt-4 whitespace-pre-wrap text-ink leading-relaxed">{template.annotation_md}</div>
      </article>

      <aside class="rounded-lg border border-line bg-panel p-6">
        <h3 class="text-sm font-semibold uppercase tracking-wider text-ink-muted">At a glance</h3>
        <dl class="mt-4 space-y-3 text-sm">
          <div class="flex justify-between">
            <dt class="text-ink-muted">Chart type</dt>
            <dd class="font-medium text-ink-strong">{template.chart_type}</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-ink-muted">Difficulty</dt>
            <dd class="font-medium text-ink-strong">{template.difficulty}</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-ink-muted">Build time</dt>
            <dd class="font-medium text-ink-strong">≈{template.build_time_min} min</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-ink-muted">Tableau Public</dt>
            <dd>
              <a href={template.tableau_public_url} class="font-medium text-brand-blue hover:underline" target="_blank" rel="noopener">
                View source →
              </a>
            </dd>
          </div>
        </dl>
      </aside>
    </section>
  </main>
</Layout>
