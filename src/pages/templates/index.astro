---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";

export const prerender = false;

const url = Astro.url;
const chartType = url.searchParams.get("chart_type") ?? "";
const difficulty = url.searchParams.getAll("difficulty");

// Build query progressively
let query = Astro.locals.supabase
  .from("tk_templates")
  .select("slug, name, subtitle, chart_type, difficulty, build_time_min, preview_image_url, tags, content_tier, author_name")
  .eq("is_published", true)
  .order("content_tier", { ascending: true })
  .order("published_at", { ascending: false });

if (chartType) query = query.eq("chart_type", chartType);
if (difficulty.length > 0) query = query.in("difficulty", difficulty);

const { data: templates, error } = await query;

// Get distinct chart_types for the dropdown
const { data: typeRows } = await Astro.locals.supabase
  .from("tk_templates")
  .select("chart_type")
  .eq("is_published", true);

const chartTypes = Array.from(new Set((typeRows ?? []).map((r) => r.chart_type))).sort();
const difficulties = ["beginner", "intermediate", "advanced"];

function chipUrl(field: string, value: string) {
  const next = new URL(url);
  const current = next.searchParams.getAll(field);
  next.searchParams.delete(field);
  if (current.includes(value)) {
    current.filter((v) => v !== value).forEach((v) => next.searchParams.append(field, v));
  } else {
    [...current, value].forEach((v) => next.searchParams.append(field, v));
  }
  return next.pathname + next.search;
}

function tierBadge(tier: number) {
  if (tier === 1) return { label: "Flagship", icon: "★", classes: "bg-brand-blue/10 text-brand-blue" };
  if (tier === 2) return { label: "Deep dive", icon: "◆", classes: "bg-purple-100 text-purple-700" };
  return null;
}
---

<Layout title="Templates · TableauKit">
  <Nav user={Astro.locals.user} />

  <main class="mx-auto max-w-6xl px-6 py-16">
    <header>
      <h1 class="text-4xl font-semibold tracking-tight text-ink-strong">Templates</h1>
      <p class="mt-3 max-w-2xl text-ink">
        Curated Tableau Public visualizations with a senior analyst's commentary —
        when to use each chart, when not to, and the gotchas you only learn the hard way.
      </p>
    </header>

    <!-- Filters -->
    <section class="mt-8 rounded-lg border border-line bg-panel p-5">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:gap-6">
        <div class="flex items-center gap-3">
          <label for="chart_type" class="text-sm font-medium text-ink-strong whitespace-nowrap">Chart type</label>
          <form method="GET" id="filter-form" class="flex items-center gap-2">
            {difficulty.map((d) => <input type="hidden" name="difficulty" value={d} />)}
            <select
              name="chart_type"
              id="chart_type"
              class="rounded-sm border border-line bg-app px-3 py-1.5 text-sm text-ink-strong focus:border-brand-blue focus:outline-none"
              onchange="this.form.submit()"
            >
              <option value="">All chart types</option>
              {chartTypes.map((ct) => (
                <option value={ct} selected={ct === chartType}>{ct}</option>
              ))}
            </select>
          </form>
        </div>

        <div class="flex flex-wrap items-center gap-2">
          <span class="text-sm font-medium text-ink-strong">Difficulty</span>
          {difficulties.map((d) => {
            const active = difficulty.includes(d);
            return (
              <a
                href={chipUrl("difficulty", d)}
                class={`rounded-sm border px-3 py-1 text-xs font-medium transition ${
                  active
                    ? "border-brand-blue bg-brand-blue text-white"
                    : "border-line bg-app text-ink-muted hover:border-ink-muted"
                }`}
              >
                {d}
              </a>
            );
          })}
          {(chartType || difficulty.length > 0) && (
            <a href="/templates" class="ml-2 text-xs text-ink-muted hover:underline">Reset</a>
          )}
        </div>

        <div class="sm:ml-auto text-sm text-ink-muted">
          {templates ? `${templates.length} template${templates.length === 1 ? "" : "s"}` : ""}
        </div>
      </div>
    </section>

    {error && (
      <div class="mt-8 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
        Failed to load templates: {error.message}
      </div>
    )}

    {templates && templates.length === 0 && (
      <div class="mt-12 rounded-lg border border-line bg-panel px-6 py-10 text-center">
        <p class="text-ink-muted">No templates match these filters. <a href="/templates" class="text-brand-blue hover:underline">Reset</a></p>
      </div>
    )}

    {templates && templates.length > 0 && (
      <div class="mt-8 grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
        {templates.map((t) => {
          const badge = tierBadge(t.content_tier ?? 3);
          return (
            <a
              href={`/templates/${t.slug}`}
              class="group relative block overflow-hidden rounded-lg border border-line bg-panel transition hover:border-ink-muted hover:shadow-card"
            >
              {badge && (
                <span class={`absolute right-3 top-3 z-10 rounded-sm px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider ${badge.classes}`}>
                  <span aria-hidden="true">{badge.icon}</span> {badge.label}
                </span>
              )}
              <div class="aspect-[16/9] overflow-hidden rounded-t-lg bg-gradient-to-br from-app to-app/60">
                {t.preview_image_url && (
                  <img src={t.preview_image_url} alt={`${t.name} preview`} class="h-full w-full object-cover transition group-hover:scale-105" loading="lazy" />
                )}
              </div>
              <div class="p-5">
                <h3 class="font-semibold text-ink-strong">{t.name}</h3>
                <p class="mt-1 line-clamp-2 text-sm text-ink-muted">{t.subtitle}</p>
                <div class="mt-4 flex flex-wrap items-center gap-2 text-[11px]">
                  <span class="rounded-sm bg-app px-2 py-1 font-medium text-ink-muted">{t.chart_type}</span>
                  <span class="rounded-sm bg-app px-2 py-1 font-medium text-ink-muted">{t.difficulty}</span>
                  {t.build_time_min && (
                    <span class="rounded-sm bg-app px-2 py-1 font-medium text-ink-muted">≈{t.build_time_min} min</span>
                  )}
                </div>
                {t.author_name && (
                  <p class="mt-3 text-xs text-ink-muted">by {t.author_name}</p>
                )}
              </div>
            </a>
          );
        })}
      </div>
    )}
  </main>
</Layout>
