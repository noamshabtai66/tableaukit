---
import Layout from "../layouts/Layout.astro";

export const prerender = false;

let error: string | null = null;
let info: string | null = null;

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const email = (formData.get("email") ?? "").toString().trim();
  const password = (formData.get("password") ?? "").toString();

  if (!email || !password) {
    error = "Email and password are required.";
  } else if (password.length < 8) {
    error = "Password must be at least 8 characters.";
  } else {
    const origin = new URL(Astro.request.url).origin;
    const { data, error: signUpError } = await Astro.locals.supabase.auth.signUp({
      email,
      password,
      options: { emailRedirectTo: `${origin}/auth/callback` },
    });

    if (signUpError) {
      error = signUpError.message;
    } else if (data.user && !data.session) {
      info = `Check your inbox at ${email} to confirm your account.`;
    } else if (data.session) {
      return Astro.redirect("/account");
    }
  }
}

if (Astro.locals.user && Astro.request.method === "GET") {
  return Astro.redirect("/account");
}
---

<Layout title="Sign up · TableauKit">
  <header class="border-b border-line bg-panel">
    <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <a href="/" class="font-semibold text-ink-strong">TableauKit</a>
      <a href="/signin" class="text-sm text-ink-muted hover:text-ink-strong">Sign in</a>
    </nav>
  </header>

  <main class="mx-auto max-w-md px-6 py-16">
    <h1 class="text-3xl font-semibold text-ink-strong">Create your account</h1>
    <p class="mt-2 text-ink-muted">Save favorites and request new templates.</p>

    {error && (
      <div class="mt-6 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
        {error}
      </div>
    )}
    {info && (
      <div class="mt-6 rounded-md border border-blue-200 bg-blue-50 px-4 py-3 text-sm text-blue-800">
        {info}
      </div>
    )}

    <form method="POST" class="mt-6 space-y-4">
      <div>
        <label for="email" class="block text-sm font-medium text-ink-strong">Email</label>
        <input
          id="email"
          name="email"
          type="email"
          autocomplete="email"
          required
          class="mt-1 w-full rounded-sm border border-line bg-panel px-3 py-2 text-ink-strong focus:border-brand-blue focus:outline-none"
        />
      </div>
      <div>
        <label for="password" class="block text-sm font-medium text-ink-strong">Password</label>
        <input
          id="password"
          name="password"
          type="password"
          autocomplete="new-password"
          minlength="8"
          required
          class="mt-1 w-full rounded-sm border border-line bg-panel px-3 py-2 text-ink-strong focus:border-brand-blue focus:outline-none"
        />
        <p class="mt-1 text-xs text-ink-muted">Minimum 8 characters.</p>
      </div>
      <button
        type="submit"
        class="w-full rounded-sm bg-brand-blue px-4 py-2.5 text-sm font-medium text-white transition hover:bg-blue-700"
      >
        Create account
      </button>
    </form>

    <p class="mt-6 text-center text-sm text-ink-muted">
      Already have an account?{" "}
      <a href="/signin" class="font-medium text-brand-blue hover:underline">Sign in</a>
    </p>
  </main>
</Layout>
