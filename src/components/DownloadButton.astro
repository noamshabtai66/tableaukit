---
interface Props {
  href: string;
  filename?: string;
  label?: string;
}

const { href, filename, label = "Download .twbx" } = Astro.props;
---

<a
  href={href}
  download={filename}
  class="inline-flex items-center gap-2 rounded-sm bg-brand-blue px-5 py-2.5 text-sm font-medium text-white shadow-soft transition hover:bg-blue-700"
>
  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
    <path d="M7 1v8m0 0L3 5m4 4l4-4M2 12h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
  {label}
</a>
